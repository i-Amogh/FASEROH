    def run_positional_encoding_ablation(self, train_data, val_data, test_data):
        \"\"\"
        Compare Transformer with sinusoidal vs learned positional encoding.
        \"\"\"
        from models import TransformerTaylorModel, ModelConfig
        
        results = {}
        
